# 04 — Metal pipeline internals
# Compute kernel inputs, steps, outputs + post-compute blit pass.
# Cross-ref: design/03-metal-pipeline.md §Compute Kernel

vars: {
  d2-config: {
    layout-engine: elk
    pad: 40
  }
}

direction: right

classes: {
  input: {
    style.fill: "#dbeafe"
    style.stroke: "#1e40af"
  }
  kernel: {
    style.fill: "#ede9fe"
    style.stroke: "#6d28d9"
  }
  output: {
    style.fill: "#dcfce7"
    style.stroke: "#15803d"
  }
  blit: {
    style.fill: "#fef3c7"
    style.stroke: "#b45309"
  }
  completion: {
    style.fill: "#fee2e2"
    style.stroke: "#b91c1c"
  }
}

Inputs: Kernel inputs (per frame) {
  IN: "inRGBAHalf\ntexture2d<half, read>\nkCVPixelFormatType_64RGBAHalf → rgba16Float" { class: input }
  U: "ColorUniforms\nbrightness, contrast, saturation\ngamma, blackBalance\nenableNaturalStream flag" { class: input }
}

Kernel: "Metal compute kernel — cam_pipeline.metal (half-float)" {
  K1: "1. read half4 at gid\n(AVFoundation delivers RGBA half directly)" { class: kernel }
  K2: "2. black balance offset + rescale\n(half math, full rate)" { class: kernel }
  K3: "3. 5-stage color pipeline\nblack balance → brightness →\ncontrast → saturation → gamma" { class: kernel }
  K4: "4. write processed\nwrite natural passthrough\nwrite tracker downscaled" { class: kernel }
  K1 -> K2 -> K3 -> K4
}

Outputs: {
  P: "processedTexture\nrgba16Float" { class: output }
  N: "naturalTexture\nrgba16Float\n(color pipeline bypassed)" { class: output }
  T: "trackerTexture\nrgba16Float\n(480px tall)" { class: output }
}

BlitPass: Post-compute blit pass (same command buffer) {
  BE: MTLBlitCommandEncoder { class: blit }
  RB1: "processed readback\nMTLBuffer[writeIndex]" { class: blit }
  TRB: "tracker readback\nMTLBuffer" { class: blit }
  ENCT: "encoder texture\n(IOSurface pool)" { class: blit }
  BE -> RB1
  BE -> TRB
  BE -> ENCT: recording only {
    style.stroke-dash: 3
  }
}

Completion: Command buffer completion {
  CH: "addCompletedHandler:\n1. check cb.status == .error\n2. Task { await onFrameReadbackComplete }\n   with expectedState guard" { class: completion }
}

Inputs.IN -> Kernel.K1
Inputs.U -> Kernel.K3

Kernel.K4 -> Outputs.P
Kernel.K4 -> Outputs.N
Kernel.K4 -> Outputs.T

Outputs.P -> BlitPass.BE: blit
Outputs.T -> BlitPass.BE: blit

BlitPass -> Completion.CH
